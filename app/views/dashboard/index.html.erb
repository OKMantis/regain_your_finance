<% content_for :page_title, "Dashboard" %>
<% yearly = params[:period] == "yearly" %>
<% multiplier = yearly ? 12 : 1 %>

<%# ── Period toggle (top of page, adapts to desktop/mobile) ───────── %>
<div class="mt-2 mb-6 lg:mt-0 flex lg:justify-between lg:items-center">
  <div class="flex bg-slate-900 lg:bg-slate-800/60 rounded-xl p-1 gap-1 w-full lg:w-auto">
    <%= link_to root_path,
        class: "flex-1 lg:flex-none lg:px-5 text-center py-2 rounded-lg text-sm font-medium transition-all duration-150 #{!yearly ? 'bg-slate-700 text-white shadow-sm' : 'text-slate-400 hover:text-slate-300'}" do %>
      Monthly
    <% end %>
    <%= link_to root_path(period: "yearly"),
        class: "flex-1 lg:flex-none lg:px-5 text-center py-2 rounded-lg text-sm font-medium transition-all duration-150 #{yearly ? 'bg-slate-700 text-white shadow-sm' : 'text-slate-400 hover:text-slate-300'}" do %>
      Yearly
    <% end %>
  </div>
</div>

<%# ── Desktop 2-column layout / Mobile stacked ─────────────────────── %>
<div class="lg:grid lg:grid-cols-5 lg:gap-8 lg:items-start">

  <%# Left column — savings hero + rate bar ──────────────────────────── %>
  <div class="lg:col-span-2">

    <%# Savings hero card %>
    <div class="mb-6">
      <div class="relative overflow-hidden rounded-2xl border border-emerald-500/25 p-6 hero-glow"
           style="background: linear-gradient(135deg, rgba(16,185,129,0.18) 0%, rgba(5,150,105,0.10) 50%, rgba(15,23,42,0.95) 100%);">
        <%# Decorative orb %>
        <div class="absolute -top-8 -right-8 w-40 h-40 rounded-full opacity-20"
             style="background: radial-gradient(circle, #34d399 0%, transparent 70%);"></div>
        <div class="relative">
          <p class="text-emerald-400 text-xs font-semibold uppercase tracking-widest mb-2">
            <%= yearly ? "Yearly" : "Monthly" %> Savings
          </p>
          <p class="text-5xl font-bold text-white tabular-nums leading-none tracking-tight">
            €<%= number_with_delimiter((@savings_monthly * multiplier / 100.0).round, delimiter: ".") %>
          </p>
          <p class="text-slate-400 text-sm mt-2">
            <% if yearly %>
              €<%= number_with_delimiter((@savings_monthly / 100.0).round, delimiter: ".") %> per month
            <% else %>
              €<%= number_with_delimiter((@savings_monthly * 12 / 100.0).round, delimiter: ".") %> per year
            <% end %>
          </p>
        </div>
      </div>
    </div>

    <%# Savings rate bar %>
    <div class="mb-6 lg:mb-0">
      <div class="bg-slate-900 rounded-2xl px-5 py-4">
        <div class="flex justify-between items-center mb-3">
          <span class="text-slate-400 text-sm font-medium">Savings rate</span>
          <span class="text-emerald-400 font-bold text-sm tabular-nums"><%= @savings_rate %>%</span>
        </div>
        <div class="h-1.5 bg-slate-800 rounded-full overflow-hidden">
          <div class="h-full rounded-full transition-all duration-700"
               style="width: <%= [[@savings_rate, 0].max, 100].min %>%; background: linear-gradient(90deg, #34d399, #10b981);"></div>
        </div>
        <p class="text-slate-600 text-xs mt-2">of income saved <%= yearly ? "this year" : "per month" %></p>
      </div>
    </div>

  </div>

  <%# Right column — income + expense breakdown ──────────────────────── %>
  <div class="lg:col-span-3">
    <div class="lg:bg-slate-900/60 lg:rounded-2xl lg:border lg:border-slate-800/60 lg:divide-y lg:divide-slate-800/60">

      <%# Income summary %>
      <div class="mt-4 mb-4 lg:mt-0 lg:mb-0 lg:px-6 lg:py-5">
        <div class="flex justify-between items-center py-3 border-b border-slate-800 lg:border-0 lg:pb-0 lg:mb-3">
          <span class="text-slate-300 font-semibold flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-emerald-500/15">
              <svg class="w-3 h-3 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
              </svg>
            </span>
            Total Income
          </span>
          <span class="text-emerald-400 font-bold tabular-nums">
            €<%= number_with_delimiter((@income_monthly * multiplier / 100.0).round, delimiter: ".") %>
          </span>
        </div>

        <% @income_items.each do |item| %>
          <div class="flex justify-between items-center py-2.5 rounded-lg hover:bg-slate-800/30 px-2 -mx-2 transition-colors duration-150">
            <span class="text-slate-400 text-sm"><%= item.name %></span>
            <span class="text-slate-300 text-sm tabular-nums font-medium">
              €<%= number_with_delimiter((item.amount_cents_monthly * multiplier / 100.0).round, delimiter: ".") %>
            </span>
          </div>
        <% end %>
      </div>

      <%# Expense summary %>
      <div class="mb-6 lg:mb-0 lg:px-6 lg:py-5">
        <div class="flex justify-between items-center py-3 border-b border-slate-800 lg:border-0 lg:pb-0 lg:mb-3">
          <span class="text-slate-300 font-semibold flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-red-500/15">
              <svg class="w-3 h-3 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
            </span>
            Total Expenses
          </span>
          <span class="text-red-400 font-bold tabular-nums">
            −€<%= number_with_delimiter((@total_expense_monthly * multiplier / 100.0).round, delimiter: ".") %>
          </span>
        </div>

        <% category_labels = { "housing" => "Housing", "subscriptions" => "Subscriptions", "investments" => "Investments", "food_entertainment" => "Food & Entertainment" } %>
        <% @expense_by_category.sort_by { |_, v| -v }.each do |category, cents| %>
          <% next if cents == 0 %>
          <div class="flex justify-between items-center py-2.5 rounded-lg hover:bg-slate-800/30 px-2 -mx-2 transition-colors duration-150">
            <span class="text-slate-400 text-sm"><%= category_labels[category] || category.humanize %></span>
            <span class="text-slate-300 text-sm tabular-nums font-medium">
              −€<%= number_with_delimiter((cents * multiplier / 100.0).round, delimiter: ".") %>
            </span>
          </div>
        <% end %>
        <div class="flex justify-between items-center py-2.5 rounded-lg hover:bg-slate-800/30 px-2 -mx-2 transition-colors duration-150">
          <span class="text-slate-400 text-sm">Property costs</span>
          <span class="text-slate-300 text-sm tabular-nums font-medium">
            −€<%= number_with_delimiter((@property_expense_monthly * multiplier / 100.0).round, delimiter: ".") %>
          </span>
        </div>
      </div>

    </div>
  </div>

</div>
