<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <title>Regain Your Finance</title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Regain Your Finance">
    <meta name="theme-color" content="#0f172a">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-slate-950 text-white antialiased">

    <%# ── Desktop sidebar ──────────────────────────────────────────── %>
    <aside class="hidden lg:fixed lg:inset-y-0 lg:left-0 lg:z-40 lg:flex lg:w-64 lg:flex-col">
      <div class="flex flex-col h-full bg-slate-900 border-r border-slate-800/60">

        <%# Logo %>
        <div class="flex items-center gap-3 px-6 py-6 border-b border-slate-800/60">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-lg shadow-emerald-500/20 flex-shrink-0">
            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <div>
            <p class="font-bold text-white tracking-tight leading-none">Regain Your Finance</p>
            <p class="text-slate-500 text-xs mt-0.5">Finance Dashboard</p>
          </div>
        </div>

        <%# Navigation links %>
        <nav class="flex-1 px-3 py-4 space-y-0.5">
          <%= link_to root_path,
              class: "flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{current_page?(root_path) ? 'bg-emerald-500/10 text-emerald-400' : 'text-slate-400 hover:text-white hover:bg-slate-800/60'}" do %>
            <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Dashboard
          <% end %>

          <%= link_to details_path,
              class: "flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{current_page?(details_path) ? 'bg-emerald-500/10 text-emerald-400' : 'text-slate-400 hover:text-white hover:bg-slate-800/60'}" do %>
            <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
            Details
          <% end %>

          <%= link_to properties_path,
              class: "flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{current_page?(properties_path) ? 'bg-emerald-500/10 text-emerald-400' : 'text-slate-400 hover:text-white hover:bg-slate-800/60'}" do %>
            <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            Properties
          <% end %>
        </nav>

        <%# Sidebar footer %>
        <div class="px-6 py-5 border-t border-slate-800/60">
          <div class="flex items-center gap-2.5">
            <div class="w-7 h-7 rounded-full bg-emerald-500/15 border border-emerald-500/20 flex items-center justify-center flex-shrink-0">
              <span class="text-emerald-400 text-xs font-semibold">OM</span>
            </div>
            <div>
              <p class="text-slate-300 text-xs font-medium">Owen Moss</p>
              <p class="text-slate-600 text-xs">Personal</p>
            </div>
          </div>
        </div>

      </div>
    </aside>

    <%# ── Main wrapper (offset on desktop for sidebar) ─────────────── %>
    <div class="flex flex-col h-full lg:pl-64">

      <%# Mobile header — hidden on desktop %>
      <header class="lg:hidden flex items-center justify-between px-5 pt-14 pb-4 bg-slate-950/95 backdrop-blur-sm sticky top-0 z-10">
        <span class="text-xl font-bold tracking-tight text-white">Regain Your Finance</span>
      </header>

      <%# Desktop topbar — hidden on mobile %>
      <header class="hidden lg:flex items-center justify-between px-8 h-[65px] border-b border-slate-800/50 sticky top-0 z-10 bg-slate-950/95 backdrop-blur-sm">
        <h1 class="text-base font-semibold text-white"><%= yield(:page_title) || "Dashboard" %></h1>
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center">
            <span class="text-emerald-400 text-xs font-bold">OM</span>
          </div>
        </div>
      </header>

      <%# Main content %>
      <main class="flex-1 overflow-y-auto px-5 pb-28 lg:pb-10 lg:px-8 lg:pt-8" id="main-content">
        <%= yield %>
      </main>

      <%# Mobile bottom navigation — hidden on desktop %>
      <nav class="lg:hidden fixed bottom-0 left-0 right-0 bg-slate-900/95 backdrop-blur-sm border-t border-slate-800/80 z-20 safe-bottom">
        <div class="flex">
          <%= link_to root_path,
              class: "flex-1 flex flex-col items-center gap-1 py-3 text-xs font-medium transition-colors #{current_page?(root_path) ? 'text-emerald-400 nav-active-indicator' : 'text-slate-500'}" do %>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span>Dashboard</span>
          <% end %>

          <%= link_to details_path,
              class: "flex-1 flex flex-col items-center gap-1 py-3 text-xs font-medium transition-colors #{current_page?(details_path) ? 'text-emerald-400 nav-active-indicator' : 'text-slate-500'}" do %>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
            <span>Details</span>
          <% end %>

          <%= link_to properties_path,
              class: "flex-1 flex flex-col items-center gap-1 py-3 text-xs font-medium transition-colors #{current_page?(properties_path) ? 'text-emerald-400 nav-active-indicator' : 'text-slate-500'}" do %>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            <span>Properties</span>
          <% end %>
        </div>
      </nav>

    </div>
  </body>
</html>
