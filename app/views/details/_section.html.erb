<div class="mb-6 lg:bg-slate-900/60 lg:rounded-2xl lg:border lg:border-slate-800/60 lg:p-5 lg:mb-0">
  <div class="flex justify-between items-center py-3 border-b border-slate-800 lg:border-slate-700/60 mb-1">
    <span class="text-slate-200 font-semibold text-sm uppercase tracking-wide"><%= title %></span>
    <span class="font-bold tabular-nums text-sm <%= color == 'emerald' ? 'text-emerald-400' : 'text-red-400' %>">
      <%= sign %>€<%= number_with_delimiter((total_cents * multiplier / 100.0).round, delimiter: ".") %>
    </span>
  </div>

  <% items.each do |item| %>
    <div class="py-0.5" data-controller="inline-edit" data-inline-edit-item-id-value="<%= item.id %>">
      <%# Display row %>
      <div data-inline-edit-target="display"
           class="flex justify-between items-center py-2.5 cursor-pointer group rounded-xl hover:bg-slate-800/50 px-2 -mx-2 transition-colors duration-150">
        <span class="text-slate-300 text-sm group-hover:text-white transition-colors duration-150"><%= item.name %></span>
        <div class="flex items-center gap-2">
          <span class="text-slate-300 text-sm tabular-nums font-medium" data-inline-edit-target="displayAmount">
            <%= sign %>€<%= number_with_delimiter((item.amount_cents_monthly * multiplier / 100.0).round, delimiter: ".") %>
          </span>
          <svg class="w-3.5 h-3.5 text-slate-700 group-hover:text-slate-400 transition-colors duration-150" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
          </svg>
        </div>
      </div>

      <%# Edit form (hidden by default) %>
      <div data-inline-edit-target="form" class="hidden">
        <%= form_with url: line_item_path(item), method: :patch, class: "bg-slate-800/80 rounded-2xl p-4 my-1 border border-slate-700/60" do |f| %>
          <input type="hidden" name="period" value="<%= yearly ? 'yearly' : '' %>">
          <p class="text-slate-300 text-sm font-medium mb-3"><%= item.name %></p>
          <div class="flex gap-3 items-start">
            <div class="flex-1">
              <label class="text-xs text-slate-500 mb-1 block">Amount (€)</label>
              <%= f.number_field :amount_cents,
                  value: (item.amount_cents / 100.0),
                  step: "0.01", min: "0",
                  class: "w-full bg-slate-700 text-white rounded-xl px-3 py-2.5 text-sm border border-slate-600 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500/30",
                  data: { inline_edit_target: "amountInput", action: "input->inline-edit#convertToCents" } %>
              <input type="hidden" name="line_item[amount_cents]" data-inline-edit-target="centsInput" value="<%= item.amount_cents %>">
            </div>
            <div class="w-32">
              <label class="text-xs text-slate-500 mb-1 block">Period</label>
              <%= f.select :billing_period,
                  LineItem.billing_periods.keys.map { |p| [p.humanize, p] },
                  { selected: item.billing_period },
                  class: "w-full bg-slate-700 text-white rounded-xl px-3 py-2.5 text-sm border border-slate-600 focus:border-emerald-500 focus:outline-none" %>
            </div>
          </div>
          <div class="flex gap-2 mt-3">
            <%= f.submit "Save", class: "flex-1 bg-emerald-500 hover:bg-emerald-400 active:bg-emerald-600 text-white text-sm font-semibold rounded-xl py-2.5 transition-colors duration-150 cursor-pointer" %>
            <button type="button" data-action="inline-edit#cancel"
                    class="flex-1 bg-slate-700 hover:bg-slate-600 active:bg-slate-800 text-slate-300 text-sm font-semibold rounded-xl py-2.5 transition-colors duration-150">
              Cancel
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
