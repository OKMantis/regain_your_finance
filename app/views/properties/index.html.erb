<%# Period toggle state %>
<% yearly = params[:period] == "yearly" %>
<% multiplier = yearly ? 12 : 1 %>

<%# ── Period toggle ─────────────────────────────────────────────── %>
<div class="flex bg-slate-900 rounded-xl p-1 mt-2 mb-6 gap-1">
  <%= link_to properties_path, class: "flex-1 text-center py-2 rounded-lg text-sm font-medium transition-all #{!yearly ? 'bg-slate-700 text-white shadow' : 'text-slate-400 hover:text-slate-300'}" do %>
    Monthly
  <% end %>
  <%= link_to properties_path(period: "yearly"), class: "flex-1 text-center py-2 rounded-lg text-sm font-medium transition-all #{yearly ? 'bg-slate-700 text-white shadow' : 'text-slate-400 hover:text-slate-300'}" do %>
    Yearly
  <% end %>
</div>

<%# ── Net property income banner ────────────────────────────────── %>
<div class="bg-slate-900 rounded-2xl px-5 py-4 mb-6 flex justify-between items-center">
  <span class="text-slate-400 text-sm font-medium">Net property income</span>
  <span class="text-emerald-400 font-bold text-lg tabular-nums">
    +€<%= number_with_delimiter((@total_net_monthly * multiplier / 100.0).round, delimiter: ".") %>
  </span>
</div>

<%# ── Property cards ────────────────────────────────────────────── %>
<% @properties.each do |property| %>
  <div class="mb-4" data-controller="property-detail">
    <%# Summary card — tap to expand %>
    <div class="bg-slate-900 rounded-2xl p-5 cursor-pointer"
         data-action="click->property-detail#toggle"
         data-property-detail-target="card">
      <div class="flex justify-between items-start mb-4">
        <div>
          <p class="text-white font-semibold"><%= property.name %></p>
          <% if property.ownership_percentage < 100 %>
            <p class="text-slate-500 text-xs mt-0.5"><%= property.ownership_percentage %>% ownership</p>
          <% end %>
        </div>
        <svg class="w-5 h-5 text-slate-500 transition-transform duration-200" data-property-detail-target="chevron"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </div>

      <div class="grid grid-cols-3 gap-3">
        <div class="bg-slate-800/60 rounded-xl p-3">
          <p class="text-slate-500 text-xs mb-1">Income</p>
          <p class="text-emerald-400 font-semibold text-sm tabular-nums">
            €<%= number_with_delimiter((property.income_cents_monthly * multiplier / 100.0).round, delimiter: ".") %>
          </p>
        </div>
        <div class="bg-slate-800/60 rounded-xl p-3">
          <p class="text-slate-500 text-xs mb-1">Expenses</p>
          <p class="text-red-400 font-semibold text-sm tabular-nums">
            -€<%= number_with_delimiter((property.expenses_cents_monthly * multiplier / 100.0).round, delimiter: ".") %>
          </p>
        </div>
        <div class="bg-slate-800/60 rounded-xl p-3">
          <p class="text-slate-500 text-xs mb-1">Net</p>
          <p class="text-white font-bold text-sm tabular-nums">
            +€<%= number_with_delimiter((property.net_cents_monthly * multiplier / 100.0).round, delimiter: ".") %>
          </p>
        </div>
      </div>
    </div>

    <%# Expense breakdown — hidden by default %>
    <div class="hidden" data-property-detail-target="detail">
      <div class="bg-slate-800/50 rounded-b-2xl -mt-2 pt-4 px-5 pb-4 border border-t-0 border-slate-700/50">
        <p class="text-slate-500 text-xs font-semibold uppercase tracking-wider mb-3">Expense Breakdown</p>

        <% property.property_expenses.order(:category, :name).each do |expense| %>
          <div class="py-0.5" data-controller="inline-edit" data-inline-edit-item-id-value="<%= expense.id %>">
            <div data-inline-edit-target="display"
                 class="flex justify-between items-center py-2 cursor-pointer group rounded-lg hover:bg-slate-700/30 px-2 -mx-2 transition-colors">
              <span class="text-slate-300 text-sm group-hover:text-white transition-colors"><%= expense.name %></span>
              <div class="flex items-center gap-2">
                <span class="text-red-400 text-sm tabular-nums">
                  -€<%= number_with_delimiter((expense.amount_cents_monthly * multiplier / 100.0).round, delimiter: ".") %>
                </span>
                <svg class="w-3 h-3 text-slate-600 group-hover:text-slate-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                </svg>
              </div>
            </div>

            <div data-inline-edit-target="form" class="hidden">
              <%= form_with url: property_expense_path(expense), method: :patch, class: "bg-slate-700/50 rounded-xl p-3 my-1" do |f| %>
                <input type="hidden" name="period" value="<%= yearly ? 'yearly' : '' %>">
                <div class="flex gap-2 items-end">
                  <div class="flex-1">
                    <label class="text-xs text-slate-500 mb-1 block"><%= expense.name %> (€)</label>
                    <%= f.number_field :amount_cents,
                        value: (expense.amount_cents / 100.0),
                        step: "0.01", min: "0",
                        class: "w-full bg-slate-600 text-white rounded-lg px-3 py-2 text-sm border border-slate-500 focus:border-emerald-500 focus:outline-none",
                        data: { inline_edit_target: "amountInput", action: "input->inline-edit#convertToCents" } %>
                    <input type="hidden" name="property_expense[amount_cents]" data-inline-edit-target="centsInput" value="<%= expense.amount_cents %>">
                  </div>
                  <%= f.select :billing_period,
                      PropertyExpense.billing_periods.keys.map { |p| [p.humanize, p] },
                      { selected: expense.billing_period },
                      class: "w-28 bg-slate-600 text-white rounded-lg px-2 py-2 text-sm border border-slate-500 focus:border-emerald-500 focus:outline-none" %>
                </div>
                <div class="flex gap-2 mt-2">
                  <%= f.submit "Save", class: "flex-1 bg-emerald-500 hover:bg-emerald-400 text-white text-xs font-semibold rounded-lg py-2 transition-colors cursor-pointer" %>
                  <button type="button" data-action="inline-edit#cancel"
                          class="flex-1 bg-slate-600 hover:bg-slate-500 text-slate-300 text-xs font-semibold rounded-lg py-2 transition-colors">
                    Cancel
                  </button>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <div class="mt-3 pt-3 border-t border-slate-700 flex justify-between">
          <span class="text-slate-400 text-sm font-medium">Rent income</span>
          <span class="text-emerald-400 text-sm font-semibold tabular-nums">
            +€<%= number_with_delimiter((property.income_cents_monthly * multiplier / 100.0).round, delimiter: ".") %>
          </span>
        </div>
        <div class="mt-1 flex justify-between">
          <span class="text-white text-sm font-bold">Net cash flow</span>
          <span class="text-white text-sm font-bold tabular-nums">
            +€<%= number_with_delimiter((property.net_cents_monthly * multiplier / 100.0).round, delimiter: ".") %>
          </span>
        </div>
      </div>
    </div>
  </div>
<% end %>
